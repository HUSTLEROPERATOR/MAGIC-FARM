// Prisma Schema for Magic Farm Event Application
// Supports secure authentication, event management, games, and collaboration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT & AUTHENTICATION
// ============================================================================

model User {
  id               String    @id @default(cuid())
  name             String?   // NextAuth standard field
  firstName        String?   // Custom field, filled during onboarding
  lastName         String?   // Custom field, filled during onboarding
  email            String    @unique
  emailVerified    DateTime?
  image            String?   // NextAuth standard field for avatar
  alias            String?   @unique // Public display name for leaderboards
  role             UserRole  @default(USER)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime? // Soft delete timestamp

  // Relations
  consents          Consent[]
  tableMemberships  TableMembership[]
  submissions       Submission[]
  clueBoardMessages ClueBoardMessage[]
  auditLogs         AuditLog[]        @relation("ActorUser")
  sessions          Session[]
  accounts          Account[]
  leaderboard       LeaderboardEntry?
  badgeAwards       BadgeAward[]

  @@index([email])
  @@index([alias])
  @@index([deletedAt])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// CONSENT & PRIVACY MANAGEMENT
// ============================================================================

model Consent {
  id                  String    @id @default(cuid())
  userId              String

  // Privacy Policy Consent (mandatory)
  privacyAcceptedAt   DateTime?
  privacyVersion      String?   // Version of policy accepted

  // Terms of Service Consent (mandatory)
  termsAcceptedAt     DateTime?
  termsVersion        String?   // Version of terms accepted

  // Marketing Consent (optional)
  marketingOptInAt    DateTime?
  marketingVersion    String?
  marketingOptOutAt   DateTime? // Track opt-out separately

  // ── Granular GDPR consents ──────────────────────────────────────
  // Required to play — platform core processing (account, gameplay, scoring, leaderboard)
  consentPlatform            Boolean   @default(false)
  // Optional — marketing by data controller (Nicola Contu / platform owner)
  consentControllerMarketing Boolean   @default(false)
  // Optional — share contact data with event host/magician
  consentShareWithHost       Boolean   @default(false)
  // Optional — host marketing (meaningful only if consentShareWithHost = true)
  consentHostMarketing       Boolean   @default(false)

  // Consent Evidence
  evidenceHash        String?   // Hash of IP + User Agent + Timestamp
  ipAddressHash       String?   // Hashed IP address
  userAgent           String?   @db.Text

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([privacyAcceptedAt])
  @@index([marketingOptInAt])
  @@map("consents")
}

// ============================================================================
// ORGANIZATION (Multi-locale support)
// ============================================================================
// Organizations represent physical venues / locales (e.g., bars, clubs).
// Each EventNight belongs to one Organization.
// This enables local (per-organization) vs global (cross-organization) leaderboards.
// Future: add seasonal leaderboard support by adding a `season` field or model.

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  events EventNight[]

  @@map("organizations")
}

// ============================================================================
// EVENT NIGHT MANAGEMENT
// ============================================================================

model EventNight {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  startsAt    DateTime
  endsAt      DateTime
  status      EventStatus @default(DRAFT)
  joinCode    String?  @unique // 6-char code for players to join this event

  // Organization this event belongs to (nullable for backward compatibility)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Pointer to the currently active round (null if none)
  currentRoundId String?

  // Rituali di apertura e chiusura (Estensione 1)
  openingNarrative  String?  @db.Text   // Testo narrativo di apertura serata
  closingNarrative  String?  @db.Text   // Testo narrativo di chiusura
  nextEventTeaser   String?  @db.Text   // Anticipazione serata successiva
  theme             String?             // Tema della serata (es. "La Notte dei Misteri")

  // Venue
  venueName         String?              // Nome del locale, es. Vecchia Fattoria

  // Host / presentatore
  hostName          String?              // Display name per l'host della serata, es. Lorenzo Mameli
  hostContact       String?              // Contatto host (uso futuro)

  // Spettatore (Estensione 7)
  spectatorEnabled  Boolean  @default(true) // Permetti modalità spettatore

  // Routine Modules (Estensione 9)
  routinesEnabled   String[] @default([])  // Array di routine IDs attive
  routinesConfig    Json?                  // { [routineId]: configObject }

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tables    Table[]
  rounds    Round[]
  alliances Alliance[]
  badges    Badge[]
  metrics   EventMetrics?

  @@index([status])
  @@index([startsAt])
  @@index([organizationId])
  @@map("event_nights")
}

enum EventStatus {
  DRAFT
  LIVE
  ENDED
}

// ============================================================================
// TABLE COLLABORATION
// ============================================================================

model Table {
  id            String   @id @default(cuid())
  eventNightId  String
  name          String   // e.g., "Table 1", "Team Mystics"
  joinCodeHash  String   // Hashed join code for security
  joinCodeSalt  String   // Salt for the hash
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  eventNight        EventNight         @relation(fields: [eventNightId], references: [id], onDelete: Cascade)
  memberships       TableMembership[]
  submissions       Submission[]
  clueBoardMessages ClueBoardMessage[]
  alliancesAsTableA Alliance[]         @relation("TableA")
  alliancesAsTableB Alliance[]         @relation("TableB")

  @@index([eventNightId])
  @@index([joinCodeHash])
  @@map("tables")
}

model TableMembership {
  id        String   @id @default(cuid())
  tableId   String
  userId    String
  joinedAt  DateTime @default(now())
  leftAt    DateTime?
  
  // Relations
  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tableId, userId])
  @@index([userId])
  @@index([tableId])
  @@map("table_memberships")
}

// ============================================================================
// GAME ROUNDS & PUZZLES
// ============================================================================

model Round {
  id           String      @id @default(cuid())
  eventNightId String
  title        String
  description  String?     @db.Text
  type         RoundType
  startsAt     DateTime?
  endsAt       DateTime?
  status       RoundStatus @default(PENDING)
  
  // Configuration JSON for specific round type settings
  configJson   Json?       // e.g., { "requireCrossTable": true, "maxAttempts": 3 }
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  // Relations
  eventNight EventNight @relation(fields: [eventNightId], references: [id], onDelete: Cascade)
  puzzles    Puzzle[]

  @@index([eventNightId])
  @@index([status])
  @@map("rounds")
}

enum RoundType {
  SINGLE_TABLE    // Each table solves independently
  MULTI_TABLE     // Requires cross-table collaboration
  INDIVIDUAL      // Individual players
}

enum RoundStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Puzzle {
  id          String   @id @default(cuid())
  roundId     String
  title       String
  prompt      String   @db.Text
  
  // Answer is hashed for security (never store plaintext)
  answerHash  String
  answerSalt  String
  
  // Scoring configuration
  scoringJson Json?    // e.g., { "basePoints": 100, "timeBonus": true, "hintPenalty": 10 }
  
  // Puzzle Type & Context (Estensioni 2, 3)
  puzzleType    PuzzleType  @default(DIGITAL)  // Tipo di enigma
  physicalHint  String?     @db.Text           // Riferimento a oggetto/luogo fisico
  environmentNote String?   @db.Text           // Note per puzzle di osservazione
  
  // Order for display
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  round       Round        @relation(fields: [roundId], references: [id], onDelete: Cascade)
  submissions Submission[]
  hints       Hint[]

  @@index([roundId])
  @@map("puzzles")
}

enum PuzzleType {
  DIGITAL       // Enigma digitale standard
  PHYSICAL      // Richiede oggetto fisico al tavolo
  OBSERVATION   // Basato su osservazione ambiente/sala
  LISTENING     // Basato su ascolto
  HYBRID        // Combinazione digitale + fisico
}

// ============================================================================
// HINTS & CLUES
// ============================================================================

model Hint {
  id            String   @id @default(cuid())
  puzzleId      String
  text          String   @db.Text
  penaltyPoints Int      @default(0) // Points deducted for using this hint
  order         Int      // Display order (progressive hints)
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  
  // Relations
  puzzle Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@index([puzzleId])
  @@map("hints")
}

// ============================================================================
// SUBMISSIONS & SCORING
// ============================================================================

model Submission {
  id             String   @id @default(cuid())
  puzzleId       String
  userId         String
  tableId        String?  // Nullable for individual rounds
  
  submittedAt    DateTime @default(now())
  answerText     String?  @db.Text // Store hashed or not at all for privacy
  isCorrect      Boolean
  
  // Scoring factors
  attemptsCount  Int      @default(1)
  timeToSolveMs  BigInt?  // Time from puzzle start to correct answer
  hintsUsed      Int      @default(0)
  pointsAwarded  Int      @default(0)
  
  // Anti-cheat flags
  flaggedReason  String?
  
  // Spettatore (Estensione 7)
  isSpectator    Boolean  @default(false) // True se submit fuori classifica
  
  // Relations
  puzzle Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  table  Table? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([puzzleId])
  @@index([userId])
  @@index([tableId])
  @@index([isCorrect])
  @@index([userId, puzzleId])
  @@index([userId, puzzleId, isCorrect])
  @@map("submissions")
}

// ============================================================================
// CLUE BOARD (In-Table Communication)
// ============================================================================

model ClueBoardMessage {
  id        String    @id @default(cuid())
  tableId   String
  userId    String
  body      String    @db.Text
  
  createdAt DateTime  @default(now())
  hiddenAt  DateTime? // For moderation
  hiddenBy  String?   // Admin user ID who hid the message
  
  // Relations
  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([userId])
  @@index([createdAt])
  @@map("clue_board_messages")
}

// ============================================================================
// CROSS-TABLE ALLIANCES
// ============================================================================

model Alliance {
  id            String         @id @default(cuid())
  eventNightId  String
  tableAId      String
  tableBId      String
  
  status        AllianceStatus @default(PENDING)
  handshakeCode String?        // One-time code for establishing alliance
  
  // Effetti concreti dell'alleanza (Estensione 4)
  effectType    AllianceEffect @default(NONE)  // Tipo di effetto
  sharedHints   Boolean        @default(false)  // Condivisione hint tra tavoli
  bonusPoints   Int            @default(0)      // Bonus/penalità punti
  commonGoal    String?        @db.Text         // Obiettivo comune
  commonGoalMet Boolean        @default(false)  // Obiettivo raggiunto?
  
  createdAt     DateTime       @default(now())
  acceptedAt    DateTime?
  dissolvedAt   DateTime?
  
  // Relations
  eventNight EventNight @relation(fields: [eventNightId], references: [id], onDelete: Cascade)
  tableA     Table      @relation("TableA", fields: [tableAId], references: [id], onDelete: Cascade)
  tableB     Table      @relation("TableB", fields: [tableBId], references: [id], onDelete: Cascade)

  @@unique([tableAId, tableBId])
  @@index([eventNightId])
  @@map("alliances")
}

enum AllianceStatus {
  PENDING
  ACTIVE
  DISSOLVED
}

enum AllianceEffect {
  NONE            // Nessun effetto speciale
  HINT_SHARING    // Condivisione suggerimenti
  POINT_BONUS     // Bonus punti per entrambi
  POINT_PENALTY   // Penalità se alleanza fallisce
  COMMON_GOAL     // Obiettivo comune da raggiungere insieme
}

// ============================================================================
// AUDIT LOGGING
// ============================================================================

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  // Nullable for system actions
  actorRole   String?  // Role at the time of action (USER, ADMIN)
  action      String   // e.g., "USER_LOGIN", "CONSENT_UPDATED", "ANSWER_SUBMITTED"
  metaJson    Json?    // Additional metadata
  ipHash      String?  // Hashed IP
  userAgent   String?  @db.Text
  
  createdAt   DateTime @default(now())
  
  // Relations
  actorUser User? @relation("ActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// LIBRARY CONTENT (Educational Magic Effects)
// ============================================================================

model LibraryEntry {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  category    String   // e.g., "Card Magic", "Illusions", "Mentalism"
  content     String   @db.Text // Educational content (not copyrighted)
  imageUrl    String?
  externalUrl String?  // Link to Wikipedia, etc.
  
  // Grimorio (Estensione 6)
  entryType       LibraryEntryType @default(ARTICLE)  // Tipo di contenuto
  linkedEventId   String?           // Collegato a una serata specifica
  linkedPuzzleId  String?           // Spiegazione di un enigma passato
  requiresEventId String?           // Sbloccabile solo dopo partecipazione
  
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
  @@index([entryType])
  @@map("library_entries")
}

enum LibraryEntryType {
  ARTICLE        // Articolo generico
  PUZZLE_EXPLAIN // Spiegazione di un enigma passato
  HISTORY        // Frammento di storia legato alla serata
  CURIOSITY      // Curiosità sull'illusionismo
  TECHNIQUE      // Tecnica magica
  LOCKED         // Contenuto sbloccabile dopo partecipazione
}

// ============================================================================
// LEADERBOARD
// ============================================================================

model LeaderboardEntry {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  events    Int      @default(0)
  riddles   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([points])
  @@map("leaderboard_entries")
}

// ============================================================================
// BADGE & RICOMPENSE (Estensione 5)
// ============================================================================

model Badge {
  id          String    @id @default(cuid())
  name        String    // es: "Primo Enigma", "Maestro dell'Osservazione"
  description String    @db.Text
  icon        String    // Emoji o URL icona
  category    BadgeCategory @default(ACHIEVEMENT)
  
  // Condizioni automatiche (opzionali)
  triggerType   String?  // es: "puzzles_solved", "events_attended", "alliance_formed"
  triggerValue  Int?     // Soglia per sblocco automatico
  
  // Legato a evento specifico (titolo di serata)
  eventNightId  String?
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  
  // Relations
  eventNight  EventNight? @relation(fields: [eventNightId], references: [id], onDelete: SetNull)
  awards      BadgeAward[]

  @@index([category])
  @@map("badges")
}

model BadgeAward {
  id        String   @id @default(cuid())
  badgeId   String
  userId    String
  reason    String?  @db.Text  // Motivo dell'assegnazione
  awardedAt DateTime @default(now())
  
  // Relations
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([badgeId, userId])
  @@index([userId])
  @@map("badge_awards")
}

enum BadgeCategory {
  ACHIEVEMENT     // Traguardo (es: 10 enigmi risolti)
  EVENT_TITLE     // Titolo di serata (es: MVP della serata)
  SPECIAL         // Badge speciale/evento
  COLLABORATION   // Legato ad alleanze/collaborazione
  STREAK          // Serie consecutiva di partecipazioni
}

// ============================================================================
// METRICHE DI SERATA (Estensione 8 — uso interno)
// ============================================================================

model EventMetrics {
  id              String   @id @default(cuid())
  eventNightId    String   @unique
  
  // Dati aggregati (anonimizzati)
  totalParticipants    Int    @default(0)
  totalSpectators      Int    @default(0)
  totalSubmissions     Int    @default(0)
  totalCorrect         Int    @default(0)
  avgSolveTimeMs       BigInt @default(0)  // Tempo medio risoluzione
  medianSolveTimeMs    BigInt @default(0)
  totalHintsUsed       Int    @default(0)
  avgHintsPerPuzzle    Float  @default(0)
  totalAlliances       Int    @default(0)
  totalMessages        Int    @default(0)
  
  // Difficoltà percepita
  hardestPuzzleId      String?  // Puzzle con meno risoluzioni
  easiestPuzzleId      String?  // Puzzle con più risoluzioni
  
  // Dettaglio per puzzle (JSON)
  puzzleMetricsJson    Json?    // Array di metriche per singolo puzzle
  
  computedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  eventNight EventNight @relation(fields: [eventNightId], references: [id], onDelete: Cascade)

  @@map("event_metrics")
}

// ============================================================================
// OPEN STAGE APPLICATIONS (Palco Aperto Magico)
// ============================================================================

model OpenStageApplication {
  id          String   @id @default(cuid())
  stageName   String   // Nome d'arte
  realName    String   // Nome reale
  email       String
  phone       String
  description String   @db.Text // Descrizione numero (max 300 caratteri)
  videoUrl    String?  // Link video facoltativo
  status      OpenStageStatus @default(PENDING)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("open_stage_applications")
}

enum OpenStageStatus {
  PENDING
  APPROVED
  REJECTED
}
